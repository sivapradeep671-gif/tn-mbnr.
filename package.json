{
  "name": "tn-mbnr",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "homepage": "https://sivapradeep671-gif.github.io/tn-mbnr/",
  "scripts": {
    "dev": "vite",
    "start": "node server/index.cjs",
    "server": "node server/index.cjs",
    "sandbox:setup": "node scripts/seed-sandbox.cjs",
    "sandbox": "set DB_PATH=./server/tn_mbnr_sandbox.db&& node scripts/seed-sandbox.cjs && node server/index.cjs",
    "db:seed": "node scripts/seed-mongo.cjs",
    "db:mongo": "node server/index.cjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "test:backend": "vitest run --dir server",
    "dev:all": "start \"TN-MBNR Grid (Backend)\" npm run server && npm run dev",
    "prod:local": "npm run build && node server/index.cjs",
    "build": "vite build",
    "build:check": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "share": "npx localtunnel --port 5173",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^7.4.4",
    "@google/generative-ai": "^0.24.1",
    "@types/leaflet": "^1.9.21",
    "body-parser": "^2.2.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "html5-qrcode": "^2.3.8",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.555.0",
    "mongodb": "^6.21.0",
    "mongoose": "^8.23.0",
    "multer": "^2.0.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.30.2",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
